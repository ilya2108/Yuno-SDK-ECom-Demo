# Yuno credentials — get from Yuno Dashboard → Settings → API Keys
YUNO_PUBLIC_API_KEY=
YUNO_PRIVATE_SECRET_KEY=
YUNO_ACCOUNT_ID=

# API base: sandbox or production
YUNO_API_BASE=https://api-sandbox.y.uno

# Local dev
PORT=3000

# Public HTTPS URL of THIS app (used for callback_url in checkout session)
# Local: https://your-ngrok-app.ngrok-free.dev (use ngrok or similar to get a public URL for local dev)
# Prod:  https://your-app.vercel.app
PUBLIC_APP_URL=https://your-ngrok-url.ngrok-free.dev

YUNO_WEBHOOK_SECRET=
YUNO_WEBHOOK_X_API_KEY=
YUNO_WEBHOOK_X_SECRET=
